# ══════════════════════════════════════════════════════════════════════
#   AI CUSTOMER SUPPORT AGENT - ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════════════════════════════
# 
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!
#
# ══════════════════════════════════════════════════════════════════════

# ── App Configuration ──
APP_NAME="AI Customer Support Agent"
NODE_ENV=development
DEBUG=true
PORT=8000

# ── Security ──
# REQUIRED: Generate a strong secret for JWT tokens (min 32 chars)
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
SECRET_KEY=your-app-secret-key

# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/customerSupport

# ── Redis Cache (Optional) ──
REDIS_URL=redis://localhost:6379/0

# ── Frontend Configuration ──
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:3001

# ── OAuth Providers ──
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-secret
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
OAUTH_REDIRECT_BASE=http://localhost:8000

# ── AI/LLM Providers (need at least ONE) ──
GROQ_API_KEY=gsk_your_groq_api_key_here
CEREBRAS_API_KEY=csk_your_cerebras_api_key_here
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here
GOOGLE_AI_KEY=your_google_ai_api_key_here
XAI_API_KEY=xai-your_xai_api_key_here

# ── Embeddings & RAG (REQUIRED) ──
JINA_API_KEY=jina_your_jina_api_key_here

# ── Web Scraping (Optional) ──
FIRECRAWL_API_KEY=fc-your_firecrawl_api_key_here
SPIDER_API_KEY=sk-your_spider_api_key_here
CRAWLBASE_API_KEY=your_crawlbase_api_key_here
SCRAPEDO_API_KEY=your_scrapedo_api_key_here

# ── Supabase (Optional) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_PROJECT_ID=your_supabase_project_id

# ── Voice/Speech (Optional) ──
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# ── Email (Optional) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=support@yourcompany.com

# ── Monitoring (Optional) ──
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
TAVILY_API_KEY=tvly-your_tavily_api_key_here
