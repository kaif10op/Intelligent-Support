# ══════════════════════════════════════════════════════════════════════
#   PRODUCTION ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════════════════════════════
#
# This file is used in production deployments (Render.com, etc.)
# Environment variables set in the deployment platform OVERRIDE these
#
# ══════════════════════════════════════════════════════════════════════

# ── App Configuration ──
NODE_ENV=production
DEBUG=false
PORT=8000

# ── Security ──
# REQUIRED: Override with actual value in deployment
JWT_SECRET=${JWT_SECRET}
SECRET_KEY=${SECRET_KEY}

# ── Database ──
# REQUIRED: Set DATABASE_URL in Render dashboard environment
# This is intentionally empty to prevent using dev credentials
DATABASE_URL=

# ── Redis ──
# OPTIONAL: Set in deployment if using Redis
REDIS_URL=${REDIS_URL}
UPSTASH_REDIS_REST_URL=${UPSTASH_REDIS_REST_URL}
UPSTASH_REDIS_REST_TOKEN=${UPSTASH_REDIS_REST_TOKEN}

# ── Frontend Configuration ──
CORS_ORIGIN=https://customer-support-client.onrender.com,https://customer-support-server.onrender.com,http://localhost:3000

# ── OAuth Providers ──
# Set in deployment platform
GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}
GOOGLE_CLIENT_SECRET=${GOOGLE_CLIENT_SECRET}
GITHUB_CLIENT_ID=${GITHUB_CLIENT_ID}
GITHUB_CLIENT_SECRET=${GITHUB_CLIENT_SECRET}
OAUTH_REDIRECT_BASE=https://customer-support-server.onrender.com
FRONTEND_URL=https://customer-support-client.onrender.com

# ── AI/LLM Providers ──
# At least ONE is required
GROQ_API_KEY=${GROQ_API_KEY}
GOOGLE_AI_KEY=${GOOGLE_AI_KEY}
JINA_API_KEY=${JINA_API_KEY}
TAVILY_API_KEY=${TAVILY_API_KEY}
DEFAULT_AI_PROVIDER=groq
DEFAULT_AI_MODEL=llama-3.3-70b-versatile
