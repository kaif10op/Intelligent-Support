generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id @default(uuid())
  googleId       String           @unique
  email          String           @unique
  name           String
  picture        String?
  role           Role             @default(USER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  knowledgeBases KnowledgeBase[]
  chats          Chat[]
  tickets        Ticket[]        @relation("UserTickets")
  assignedTickets Ticket[]       @relation("AdminTickets")
  ticketMessages TicketNote[]    // Messages sent by this user in tickets
  auditLogs      AuditLog[] @relation("AdminLogs") // Admin actions performed by this user
}


enum Role {
  USER
  ADMIN
}

model KnowledgeBase {
  id          String       @id @default(uuid())
  title       String
  description String?
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   Document[]
  chats       Chat[]
  versions    KBVersion[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model KBVersion {
  id          String       @id @default(uuid())
  kbId        String
  kb          KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade)
  versionNumber Int        // Sequential version number
  title       String       // KB title at this version
  description String?      // KB description at this version
  docCount    Int          // Number of documents in this version
  docIds      String[]     // List of document IDs in this version (JSON array)
  changelog   String?      // What changed in this version
  createdAt   DateTime     @default(now())

  @@index([kbId])
  @@unique([kbId, versionNumber])
}

model Document {
  id        String          @id @default(uuid())
  filename  String
  type      String
  size      Int
  kbId      String
  kb        KnowledgeBase   @relation(fields: [kbId], references: [id], onDelete: Cascade)
  chunks    DocumentChunk[]
  createdAt DateTime        @default(now())
}

model DocumentChunk {
  id        String    @id @default(uuid())
  content   String
  embedding Float[]
  docId     String
  document  Document  @relation(fields: [docId], references: [id], onDelete: Cascade)
}

model Chat {
  id        String    @id @default(uuid())
  title     String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kbId      String
  kb        KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade)
  messages  Message[]
  tickets   Ticket[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id         String   @id @default(uuid())
  role       String   // 'user' or 'ai'
  content    String
  sources    Json?    // Store exact chunk matches
  confidence Float?   // AI confidence score (0-1)
  rating     Int?     // 1 for 👍, -1 for 👎
  feedback   String?  // Optional text feedback
  chatId     String
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Ticket {
  id          String       @id @default(uuid())
  title       String
  description String
  status      TicketStatus @default(OPEN)
  priority    Priority     @default(MEDIUM)
  userId      String
  user        User         @relation("UserTickets", fields: [userId], references: [id], onDelete: Cascade)
  assignedToId String?
  assignedTo  User?        @relation("AdminTickets", fields: [assignedToId], references: [id])
  chatId      String?
  chat        Chat?        @relation(fields: [chatId], references: [id])
  notes       TicketNote[]
  dueAt       DateTime?    // SLA due date
  isOverdue   Boolean      @default(false) // Helper field for overdue status
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TicketNote {
  id        String   @id @default(uuid())
  content   String
  role      String   @default("admin") // "admin" or "user" - who sent the message
  adminId   String?  // NULL if user-created
  userId    String?  // NULL if admin-created
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(uuid())
  adminId     String
  admin       User     @relation("AdminLogs", fields: [adminId], references: [id], onDelete: Cascade)
  action      String   // "ticket_status_updated", "ticket_assigned", "user_role_changed", etc.
  resourceId  String?  // ID of the affected resource (ticket, user, etc.)
  resourceType String? // "ticket", "user", "kb", etc.
  changes     Json?    // What changed: { field: "oldValue" -> "newValue" }
  description String?  // Human-readable description
  createdAt   DateTime @default(now())
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
