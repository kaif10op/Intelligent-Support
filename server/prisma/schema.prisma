generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SUPPORT_AGENT
  USER
}

model User {
  id                  String          @id @default(uuid())
  googleId            String          @unique
  email               String          @unique
  name                String
  picture             String?
  role                UserRole        @default(USER)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  auditLogs           AuditLog[]      @relation("AdminLogs")
  chats               Chat[]
  knowledgeBases      KnowledgeBase[]
  assignedTickets     Ticket[]        @relation("AdminTickets")
  tickets             Ticket[]        @relation("UserTickets")
  ticketMessages      TicketNote[]
  sentMessages        Message[]       @relation("MessageSenders")
  assignedChats       Chat[]          @relation("ChatAssignments")
}

model KnowledgeBase {
  id          String       @id @default(uuid())
  title       String
  description String?
  userId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  chats       Chat[]
  documents   Document[]
  versions    KBVersion[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KBVersion {
  id            String        @id @default(uuid())
  kbId          String
  versionNumber Int
  title         String
  description   String
  docCount      Int
  docIds        String[]
  changelog     String        @default("")
  createdAt     DateTime      @default(now())
  kb            KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade)

  @@unique([kbId, versionNumber])
}

model Document {
  id        String          @id @default(uuid())
  filename  String
  type      String
  size      Int
  kbId      String
  createdAt DateTime        @default(now())
  kb        KnowledgeBase   @relation(fields: [kbId], references: [id], onDelete: Cascade)
  chunks    DocumentChunk[]
}

model DocumentChunk {
  id        String   @id @default(uuid())
  content   String
  embedding Float[]
  docId     String
  document  Document @relation(fields: [docId], references: [id], onDelete: Cascade)
}

model Chat {
  id               String              @id @default(uuid())
  title            String
  userId           String
  kbId             String
  assignedAgentId  String?             // Support agent assigned to this chat
  isClosed         Boolean             @default(false)
  closedAt         DateTime?
  closedBy         String?
  metadata         Json?               // Stores summary, rating, etc.
  tags             String[]            @default([])
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  kb               KnowledgeBase       @relation(fields: [kbId], references: [id], onDelete: Cascade)
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAgent    User?               @relation("ChatAssignments", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  messages         Message[]
  tickets          Ticket[]
  conversationTags ConversationTag[]   @relation("ChatTags")

  @@index([userId])
  @@index([kbId])
  @@index([assignedAgentId])
  @@index([isClosed])
  @@index([userId, createdAt(sort: Desc)])
  @@index([kbId, createdAt(sort: Desc)])
}

model Message {
  id         String              @id @default(uuid())
  role       String              // 'user', 'assistant', 'human', 'system'
  content    String
  sources    Json?
  confidence Float?
  rating     Int?
  feedback   String?
  chatId     String
  userId     String?             // For human/agent messages - who sent it
  senderName String?             // Display name of message sender
  senderRole String?             // Role of sender (ADMIN, SUPPORT_AGENT, USER)
  createdAt  DateTime            @default(now())
  chat       Chat                @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender     User?               @relation("MessageSenders", fields: [userId], references: [id], onDelete: SetNull)
  tags       ConversationTag[]   @relation("MessageTags")

  @@index([chatId])
  @@index([chatId, createdAt(sort: Asc)])
  @@index([role])
  @@index([userId])
  @@index([senderRole])
  @@index([confidence])
}

model Ticket {
  id                      String           @id @default(uuid())
  title                   String
  description             String
  status                  TicketStatus     @default(OPEN)
  priority                Priority         @default(MEDIUM)
  userId                  String
  assignedToId            String?
  chatId                  String?
  dueAt                   DateTime?
  isOverdue               Boolean          @default(false)
  escalationLevel         Int              @default(0)
  escalationReason        String?
  escalatedAt             DateTime?
  escalatedToId           String?
  queueStatus             String           @default("inbox")
  slaBreach               Boolean          @default(false)
  slaBreachAt             DateTime?
  internalNotes           String?
  autoSuggestedReplyId    String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  assignedTo              User?            @relation("AdminTickets", fields: [assignedToId], references: [id])
  chat                    Chat?            @relation(fields: [chatId], references: [id])
  user                    User             @relation("UserTickets", fields: [userId], references: [id], onDelete: Cascade)
  notes                   TicketNote[]

  @@index([userId])
  @@index([status])
  @@index([assignedToId])
  @@index([queueStatus])
  @@index([userId, status, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([isOverdue])
  @@index([priority, createdAt(sort: Desc)])
}

model TicketNote {
  id                String   @id @default(uuid())
  content           String
  role              String   @default("admin")
  adminId           String?
  userId            String?
  ticketId          String
  isAutoSuggested   Boolean  @default(false)
  approvalStatus    String   @default("pending")
  approvedAt        DateTime?
  createdAt         DateTime @default(now())
  ticket            Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user              User?    @relation(fields: [userId], references: [id])

  @@index([ticketId])
}

model AuditLog {
  id           String   @id @default(uuid())
  adminId      String
  action       String
  resourceId   String?
  resourceType String?
  changes      Json?
  description  String?
  createdAt    DateTime @default(now())
  admin        User     @relation("AdminLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

model Webhook {
  id        String              @id @default(uuid())
  name      String              @unique
  url       String
  events    String[]
  active    Boolean             @default(true)
  secret    String?
  retryPolicy Json?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  deliveries WebhookDelivery[]

  @@index([active])
  @@index([createdAt(sort: Desc)])
}

model WebhookDelivery {
  id        String   @id @default(uuid())
  webhookId String
  event     String
  payload   Json
  status    String   @default("pending")
  attempts  Int      @default(0)
  lastError String?
  responseCode Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  webhook   Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
  @@index([event])
  @@index([webhookId, status, createdAt(sort: Desc)])
}

model ConversationTag {
  id        String   @id @default(uuid())
  tag       String
  category  String
  chatId    String?
  messageId String?
  confidence Float  @default(1.0)
  source    String  @default("ai_analysis")
  createdAt DateTime @default(now())
  chat      Chat?    @relation("ChatTags", fields: [chatId], references: [id], onDelete: Cascade)
  message   Message? @relation("MessageTags", fields: [messageId], references: [id], onDelete: Cascade)

  @@index([tag])
  @@index([chatId])
  @@index([messageId])
  @@index([category])
}

model TicketTemplate {
  id        String   @id @default(uuid())
  name      String
  category  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model AdminQueueItem {
  id        String   @id @default(uuid())
  ticketId  String   @unique
  status    String   @default("pending")
  priorityScore Float @default(0.0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priorityScore])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Plugin {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  version     String
  description String?
  enabled     Boolean  @default(false)
  webhookUrl  String?
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
