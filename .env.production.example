# ══════════════════════════════════════════════════════════════════════
#   AI CUSTOMER SUPPORT AGENT - PRODUCTION ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════════════════════════════
# 
# Instructions:
# 1. Copy this file to .env.production
# 2. Fill in your actual production values
# 3. Never commit .env.production to version control!
#
# ══════════════════════════════════════════════════════════════════════

# ── App Configuration ──
APP_NAME="AI Customer Support Agent (Production)"
NODE_ENV=production
DEBUG=false
SERVER_PORT=8000
CLIENT_PORT=3000

# ── Security ──
# REQUIRED: Generate a strong secret for JWT tokens (min 32 chars)
# openssl rand -base64 32
JWT_SECRET=your-production-jwt-secret-key-change-me
SECRET_KEY=your-production-app-secret-key-change-me

# ── Database ──
# Production PostgreSQL URL
DATABASE_URL=postgresql://user:password@production-db-host:5432/db_name

# ── Redis Cache ──
# Production Redis URL
REDIS_URL=redis://production-redis-host:6379/0

# ── Frontend/CORS Configuration ──
# The URL where your frontend is hosted
CORS_ORIGIN=https://your-domain.com,https://api.your-domain.com

# ── OAuth Providers ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
OAUTH_REDIRECT_BASE=https://api.your-domain.com

# ── AI/LLM Providers ──
GROQ_API_KEY=your-groq-api-key
GOOGLE_AI_KEY=your-google-ai-key
JINA_API_KEY=your-jina-api-key
TAVILY_API_KEY=your-tavily-api-key

# ── Supabase (Optional) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Email (Optional) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=support@your-domain.com

# ── Vite Frontend Arguments (Used during build) ──
VITE_API_URL=https://api.your-domain.com
VITE_SOCKET_URL=https://api.your-domain.com
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key
